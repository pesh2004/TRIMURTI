# Copy this file to .env and fill in real values for local dev.
# Do NOT commit .env. Production secrets live in AWS Secrets Manager / DO env.

# ---- Environment ----
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:5173
LOG_LEVEL=debug
TZ=Asia/Bangkok

# ---- PostgreSQL ----
# Matches docker-compose.yml
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=trimurti
POSTGRES_PASSWORD=trimurti_dev_only
POSTGRES_DB=trimurti
DATABASE_URL=postgres://trimurti:trimurti_dev_only@localhost:5432/trimurti?sslmode=disable

# ---- Redis ----
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Auth / Session ----
# Opaque session tokens live in Redis; this secret signs short-lived JWT
# only for optional stateless checks. Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_32_BYTES_HEX
SESSION_TTL_MINUTES=30
SESSION_COOKIE_NAME=trimurti_sess
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false

# Password hashing (argon2id)
ARGON2_MEMORY_KB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# ---- Dev mail sink (mailhog) ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@trimurti.local

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Rate limit ----
RATE_LIMIT_PER_MINUTE=100
LOGIN_RATE_LIMIT_PER_15MIN=5
