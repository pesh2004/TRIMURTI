# Production env template. Copy to `.env` in the REPO ROOT on the droplet and
# fill in real values. NEVER commit .env.
#
# Generate strong secrets:
#   openssl rand -hex 32      # for SESSION_SECRET, PII_ENCRYPTION_KEY
#   openssl rand -hex 24      # for POSTGRES_PASSWORD  (hex only — base64
#                             #  can include `/` which breaks DATABASE_URL)
#   openssl rand -base64 24   # for REDIS_PASSWORD (passed as env, not URL)
#
# deploy/preflight.sh validates this file before every deploy. It refuses
# the deploy if any secret below is empty, contains a CHANGE_ME placeholder,
# or is shorter than 32 chars. See deploy/SECRETS.md for rotation procedures.

# ---- Public-facing URL / domain ----
# If you have a domain: DOMAIN=erp.example.com, APP_BASE_URL=https://erp.example.com
# If you only have an IP (sslip.io gives free wildcard DNS):
#   DOMAIN=<IP>.sslip.io
#   APP_BASE_URL=https://<IP>.sslip.io
# If you want HTTP only (no domain, no TLS): leave DOMAIN empty.
DOMAIN=
APP_BASE_URL=http://localhost
COOKIE_DOMAIN=
ACME_EMAIL=admin@example.com

# ---- Postgres ----
POSTGRES_USER=trimurti
POSTGRES_PASSWORD=CHANGE_ME_strong_random_24_bytes
POSTGRES_DB=trimurti

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_strong_random_24_bytes

# ---- App session ----
SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32

# ---- PII field-level encryption (pgcrypto) ----
# Rotates invalidate all encrypted rows — treat like the master DB password.
# Generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ---- Seed admin (used once by `docker compose run --rm seed`) ----
SEED_ADMIN_EMAIL=admin@example.com
# Leave blank to auto-generate a random password (printed to stdout).
SEED_ADMIN_PASSWORD=

# ---- SMTP (password reset emails; deploy/SECRETS.md has provider examples) ----
# Leave SMTP_HOST empty to use the server-log fallback (the reset URL is
# printed to `docker compose logs backend`, useful for test servers
# before you've picked a provider).
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=no-reply@example.com
SMTP_USER=
SMTP_PASS=

# ---- DigitalOcean Spaces (for nightly backup) ----
# Create a Spaces bucket + access key at:
#   https://cloud.digitalocean.com/spaces
SPACES_BUCKET=trimurti-backup
SPACES_REGION=sgp1
SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
